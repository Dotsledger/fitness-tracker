# ============================================================================
# Credenciales de Supabase para acceso por TERMINAL (Claude Code / psql / scripts)
# ----------------------------------------------------------------------------
# 1. Copia este archivo a  .env.local   (que está en .gitignore, no se versiona)
# 2. Rellena los valores desde el dashboard de Supabase.
#
# OJO con la diferencia de claves:
#   - anon (pública)      -> va en js/config.js (frontend). NO va aquí.
#   - service_role (secreta) -> SOLO aquí. Salta RLS. Nunca en el frontend ni en git.
# ============================================================================

# Project Settings → API → Project URL
SUPABASE_URL="https://TU-PROYECTO.supabase.co"

# Project Settings → API → service_role (secret)  ← NO la anon
SUPABASE_SERVICE_ROLE_KEY="TU_SERVICE_ROLE_KEY"

# Project Settings → Database → Connection string → URI  (modo "Session" o "Transaction")
# Sustituye [YOUR-PASSWORD] por la contraseña de la base de datos.
# Ejemplo (pooler): postgresql://postgres.TU-REF:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.TU-PROYECTO.supabase.co:5432/postgres"
